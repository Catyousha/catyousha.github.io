n                    }\r\n                    \r\n                </div>\r\n                </>\r\n                )\r\n            }\r\n        </div>\r\n    )\r\n}\r\n\r\nexport default Projects;","C:\\Users\\madhanel\\GudangKode\\ReactJS\\portofolio\\src\\Components\\ProjectsList.js",["108"],"C:\\Users\\madhanel\\GudangKode\\ReactJS\\Portofolio\\src\\index.js",[],["109","110"],"C:\\Users\\madhanel\\GudangKode\\ReactJS\\Portofolio\\src\\App.js",["111","112","113","114"],"C:\\Users\\madhanel\\GudangKode\\ReactJS\\Portofolio\\src\\Components\\Sidebar.js",["115"],"import React from 'react';\r\nimport SidebarLink from './SidebarLink'\r\n\r\nconst Sidebar = ({active, link}) => {\r\n    return(\r\n        <div id=\"sidebar\" className=\"col-span-2 py-3 cus-shadow side-bg\">\r\n            <img onClick={()=>link(0)} id=\"sidebar-img\" className={\"cus-shadow rounded-full my-8 mx-auto \" + ((active === 0)? \"act-border\":\"\")} width=\"100\" src=\"./pictures/profile.jpg\"/>\r\n            <div className=\"text-center\">\r\n                <SidebarLink link={() => link(1)} size=\"45\" text=\"Projects\" active={(active === 1)}/><br/>\r\n                <SidebarLink link={() => link(2)} size=\"45\" text=\"Experience\"  active={(active === 2)}/><br/>\r\n                <SidebarLink link={() => link(3)} size=\"45\" text=\"Contact\"  active={(active === 3)}/><br/>\r\n            </div>\r\n        </div>\r\n    )\r\n}\r\n\r\nexport default Sidebar;","C:\\Users\\madhanel\\GudangKode\\ReactJS\\Portofolio\\src\\Components\\Profile.js",["116"],"import React from 'react';\r\n\r\nconst Profile = () => {\r\n    return(\r\n        <div id=\"profile\" className=\"col-span-10 text-center\">\r\n            <img className=\"cus-shadow rounded-md mx-auto mt-28\" width=\"120\" height=\"120\" src=\"./pictures/profile.jpg\"/>\r\n            <div className=\"pt-4 mx-32\">\r\n                <p className=\"text-title\">Hi there, my name is Jaka!</p>\r\n                <p className=\"side-text\">My name is Jaka Asa Baldan Ahmad, i’m just a random informatics student at Universitas Negeri Malang since 2019. I’m interested in back-end web development especially things about NodeJS, Codeigniter, and Laravel.</p>\r\n            </div>\r\n        </div>\r\n    )\r\n}\r\n\r\nexport default Profile;","C:\\Users\\madhanel\\GudangKode\\ReactJS\\Portofolio\\src\\Components\\Projects.js",[],"C:\\Users\\madhanel\\GudangKode\\ReactJS\\Portofolio\\src\\Components\\SidebarLink.js",["117","118","119"],"import React from 'react';\r\n\r\n\r\nconst SidebarLink = ({size, text, active, link}) => {\r\n\r\n    return (\r\n        <button onClick={link} className={\"sidebar-link my-5 py-2 px-5 \" + (active===true ? \"act-bg cus-shadow mx-1\":\"\")}>\r\n                {(text === \"Projects\") ? <>\r\n                        <img className=\"mx-auto\" width={size} height={size} src=\"./pictures/projects-icon.svg\"/>\r\n                        </>\r\n                    : (text === \"Experience\") ? <>\r\n                        <img className=\"mx-auto\" width={size} height={size} src=\"./pictures/experience-icon.svg\"/>\r\n                        </>\r\n                    : (text === \"Contact\") ? <>\r\n                        <img className=\"mx-auto\" width={size} height={size} src=\"./pictures/contact-icon.svg\"/>\r\n                    </> : 0\r\n                }\r\n            <p className=\"side-text\">{text}</p>\r\n        </button>\r\n    )\r\n\r\n}\r\n\r\nexport default SidebarLink","C:\\Users\\madhanel\\GudangKode\\ReactJS\\Portofolio\\src\\Components\\ProjectsList.js",["120"],"import React from 'react'\r\n\r\nconst ProjectsList = () => {\r\n    return (\r\n    <div className=\"col-span-1 p-3 act-bg cus-shadow\">\r\n        <img src=\"./pictures/projects-pic.png\" className=\"object-fill rounded-md h-32 w-full\"/>\r\n        <div className=\"flex justify-between\">\r\n            <div className=\"pl-3\">\r\n                <h3 className=\"sub-title-text mt-2\">KARYAKU<