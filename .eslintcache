gCount":0,"source":"59","usedDeprecatedRules":"48"},{"filePath":"60","messages":"61","errorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":"62","usedDeprecatedRules":"48"},{"filePath":"63","messages":"64","errorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"65","usedDeprecatedRules":"48"},{"filePath":"66","messages":"67","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"68","usedDeprecatedRules":"48"},{"filePath":"69","messages":"70","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"71"},"h7cwl4",{"filePath":"72","messages":"73","errorCount":0,"warningCount":4,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"74","messages":"75","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"76","usedDeprecatedRules":"71"},{"filePath":"77","messages":"78","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"79","usedDeprecatedRules":"71"},{"filePath":"80","messages":"81","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"71"},{"filePath":"82","messages":"83","errorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":"84","usedDeprecatedRules":"71"},{"filePath":"85","messages":"86","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"87","usedDeprecatedRules":"71"},{"filePath":"88","messages":"89","errorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"90","messages":"91","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"92","usedDeprecatedRules":"93"},{"filePath":"94","messages":"95","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"48"},{"filePath":"96","messages":"97","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"98","usedDeprecatedRules":"48"},{"filePath":"99","messages":"100","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"48"},{"filePath":"101","messages":"102","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"103","usedDeprecatedRules":"48"},"C:\\Users\\madhanel\\GudangKode\\ReactJS\\portofolio\\src\\index.js",[],["104","105"],"C:\\Users\\madhanel\\GudangKode\\ReactJS\\portofolio\\src\\App.js",["106","107","108","109","110"],"import React, { useState, useEffect } from 'react';\nimport logo from './logo.svg';\nimport Sidebar from './Components/Sidebar'\nimport Profile from './Components/Profile'\nimport Projects from './Components/Projects'\nimport Experiences from './Components/Experiences'\nimport './styles/tailwind.css';\nimport './styles/App.css';\nimport \"react-multi-carousel/lib/styles.css\";\nimport Contacts from './Components/Contacts';\n\nconst useKeyPress = function(targetKey) {\n  const [keyPressed, setKeyPressed] = useState(false);\n\n  function downHandler({ key }) {\n    if (key === targetKey) {\n      setKeyPressed(true);\n    }\n  }\n\n  const upHandler = ({ key }) => {\n    if (key === targetKey) {\n      setKeyPressed(false);\n    }\n  };\n\n  React.useEffect(() => {\n    window.addEventListener(\"keydown\", downHandler);\n    window.addEventListener(\"keyup\", upHandler);\n\n    return () => {\n      window.removeEventListener(\"keydown\", downHandler);\n      window.removeEventListener(\"keyup\", upHandler);\n    };\n  });\n\n  return keyPressed;\n};\n\nconst useHandleScroll = () => {\n  const [pos, setPos] = useState({top: false, bottom: false});\n\n  const checkPos = () => {\n    setPos({\n      top: window.pageYOffset === 0,\n      bottom: Math.ceil(window.innerHeight + window.scrollY) >= document.documentElement.scrollHeight\n    })\n  }\n\n  React.useEffect(() => {\n    window.addEventListener('scroll', checkPos);\n\n    return () => {\n      window.removeEventListener('scroll', checkPos);\n    };\n  });\n\n  return pos;\n};\n\n\n\nfunction App() {\n  const [comp, setComp] = useState([<Profile/>, <Projects/>, <Experiences/>, <Contacts/>])\n  const [posY, setPosY] = useState(0)\n  const downPress = useKeyPress(\"ArrowDown\");\n  const upPress = useKeyPress(\"ArrowUp\");\n  const position = useHandleScroll();\n\n  useEffect(() => {\n    if ((posY+1 < comp.length) && downPress) {\n      setPosY(posY+1)\n    }\n  }, [downPress]);\n\n  useEffect(() => {\n    if ((posY-1 >= 0) && upPress) {\n      setPosY(posY-1)\n    \n    }\n  }, [upPress]);\n  return (\n    <>\n    <Sidebar active={posY} link={(num) => setPosY(num)}/>\n    {comp[posY]}\n    </>\n  );\n}\n\nexport default App;\n","C:\\Users\\madhanel\\GudangKode\\ReactJS\\portofolio\\src\\reportWebVitals.js",[],"C:\\Users\\madhanel\\GudangKode\\ReactJS\\portofolio\\src\\Components\\Sidebar.js",["111"],"import React from 'react';\r\nimport SidebarLink from './SidebarLink'\r\n\r\nconst Sidebar = ({active, link}) => {\r\n    return(\r\n        <div id=\"sidebar\" className=\"z-10 lg:col-span-2 cus-shadow side-bg lg:py-3\">\r\n            <div id=\"sidebar-links\" className=\"lg:text-center\">\r\n                \r\n                <img onClick={()=>link(0)} id=\"sidebar-img\" className={\"cus-shadow rounded-full my-5 lg:my-8 lg:mx-auto \" + ((active === 0)? \"act-border\":\"\")} src=\"./pictures/profile.jpg\"/>\r\n                <SidebarLink link={() => link(1)} text=\"Projects\" active={(active === 1)}/><br/>\r\n                <SidebarLink link={() => link(2)} text=\"Experience\"  active={(active === 2)}/><br/>\r\n                <SidebarLink link={() => link(3)} text=\"Contact\"  active={(active === 3)}/><br/>\r\n            </div>\r\n        </div>\r\n    )\r\n}\r\n\r\nexport default Sidebar;","C:\\Users\\madhanel\\GudangKode\\ReactJS\\portofolio\\src\\Components\\Profile.js",["112"],"import React from 'react';\r\n\r\nconst Profile = () => {\r\n    return(\r\n        <div id=\"profile\" className=\"main-page lg:col-span-10 text-center\">\r\n            <img className=\"cus-shadow rounded-md mx-auto mt-14 lg:mt-28\" width=\"120\" height=\"120\" src=\"./pictures/profile.jpg\"/>\r\n            <div className=\"pt-4 lg:mx-32\">\r\n                <p className=\"text-title\">Hi there, my name is Jaka</p>\r\n                <p className=\"side-text\">My name is Jaka Asa Baldan Ahmad, i’m just a random informatics student at Universitas Negeri Malang since 2019. Currently interested in web development especially things about javascript frameworks; for example NodeJS, ReactJS, and VueJS.</p>\r\n                <p className=\"side-text mt-6\"> This portfolio is made using ReactJS and Tailwind CSS</p>\r\n            </div>\r\n        </div>\r\n    )\r\n}\r\n\r\nexport default Profile;","C:\\Users\\madhanel\\GudangKode\\ReactJS\\portofolio\\src\\Components\\SidebarLink.js",["113","114","115"],"import React from 'react';\r\n\r\n\r\nconst SidebarLink = ({text, active, link}) => {\r\n\r\n    return (\r\n        <button onClick={link} className={\"sidebar-link my-5 lg:py-2 lg:px-5  \" + (active===true ? \"act-bg cus-shadow\":\"\")}>\r\n                {(text === \"Projects\") ? <>\r\n                        <img className=\"mx-auto sidebar-icon\"  src=\"./pictures/projects-icon.svg\"/>\r\n                        </>\r\n                    : (text === \"Experience\") ? <>\r\n                        <img className=\"mx-auto sidebar-icon\"  src=\"./pictures/experience-icon.svg\"/>\r\n                        </>\r\n                    : (text === \"Contact\") ? <>\r\n                        <img className=\"mx-auto sidebar-icon\"  src=\"./pictures/contact-icon.svg\"/>\r\n                    </> : 0\r\n                }\r\n            <p className=\"sidebar-text\">{text}</p>\r\n        </button>\r\n    )\r\n\r\n}\r\n\r\nexport default SidebarLink","C:\\Users\\madhanel\\GudangKode\\ReactJS\\portofolio\\src\\Components\\Projects.js",["116","117"],"import React, { useState, useEffect } from 'react';\r\nimport ProjectsDetail from './ProjectsDetail';\r\nimport ProjectsList from './ProjectsList'\r\n\r\nconst Projects = () => {\r\n    const [projectView, setProjectView] = useState(-1);\r\n    const projectData = require('../Database/projects.json').projects\r\n    console.log(projectData)\r\n    const viewHandler = {\r\n        viewBtn: (id) => {\r\n            setProjectView(id)\r\n        },\r\n        backBtn: () => {\r\n            setProjectView(-1)\r\n        }\r\n    }\r\n\r\n    \r\n    return(\r\n        <div id=\"projects\" className=\"main-page lg:col-span-10 lg:my-5 py-2 lg:px-10\">\r\n            {(projectView != -1)?\r\n                <ProjectsDetail data={projectData[projectView]}  handler={viewHandler}/> \r\n                :(\r\n                <>\r\n                <p className=\"text-title\">Projects</p>\r\n                <p className=\"side-text\">Some projects that I work on...</p>\r\n                <div className=\"mt-3 grid grid-cols-1 lg:grid-cols-2 gap-x-10 gap-y-6\">\r\n                    {projectData.map((project) => \r\n                        <ProjectsList data={project} handler={viewHandler}/>\r\n                    )\r\n                    }\r\n                    \r\n                </div>\r\n                </>\r\n                )\r\n            }\r\n        </div>\r\n    )\r\n}\r\n\r\nexport default Projects;","C:\\Users\\madhanel\\GudangKode\\ReactJS\\portofolio\\src\\Components\\ProjectsList.js",["118"],"import React from 'react'\r\n\r\nconst ProjectsList = ({data, handler}) => {\r\n    return (\r\n    <div className=\"list-anim col-span-1 p-3 act-bg cus-shadow\">\r\n        <img src={\"./pictures/projects/\"+data.img[0]} className=\"object-fill rounded-md h-32 w-full\"/>\r\n        <div className=\"flex justify-between\">\r\n            <div className=\"pl-3\">\r\n                <h3 className=\"sub-title-text mt-2\">{data.title}</h3>\r\n                <p className=\"side-text\">As <b className=\"font-bold\">{data.role}</b></p>\r\n            </div>\r\n            <button onClick={() => {handler.viewBtn(data.id)}} style={{backgroundColor: \"#37393E\", color:\"#cdcdcd\"}}\r\n                className=\"project-btn cus-shadow w-12 h-12 mt-5 mr-3 rounded-full font-bold \r\n                text-3xl text-center\">\r\n                &gt;\r\n            </button>\r\n        </div>\r\n    </div>\r\n    )\r\n}\r\n\r\nexport default ProjectsList","C:\\Users\\madhanel\\GudangKode\\ReactJS\\Portofolio\\src\\index.js",[],["119","120"],"C:\\Users\\madhanel\\GudangKode\\ReactJS\\Portofolio\\src\\App.js",["121","122","123","124"],"C:\\Users\\madhanel\\GudangKode\\ReactJS\\Portofolio\\src\\Components\\Sidebar.js",["125"],"import React from 'react';\r\nimport SidebarLink from './SidebarLink'\r\n\r\nconst Sidebar = ({active, link}) => {\r\n    return(\r\n        <div id=\"sidebar\" className=\"col-span-2 py-3 cus-shadow side-bg\">\r\n            <img onClick={()=>link(0)} id=\"sidebar-img\" className={\"cus-shadow rounded-full my-8 mx-auto \" + ((active === 0)? \"act-border\":\"\")} width=\"100\" src=\"./pictures/profile.jpg\"/>\r\n            <div className=\"text-center\">\r\n                <SidebarLink link={() => link(1)} size=\"45\" text=\"Projects\" active={(active === 1)}/><br/>\r\n                <SidebarLink link={() => link(2)} size=\"45\" text=\"Experience\"  active={(active === 2)}/><br/>\r\n                <SidebarLink link={() => link(3)} size=\"45\" text=\"Contact\"  active={(active === 3)}/><br/>\r\n            </div>\r\n        </div>\r\n    )\r\n}\r\n\r\nexport default Sidebar;","C:\\Users\\madhanel\\GudangKode\\ReactJS\\Portofolio\\src\\Components\\Profile.js",["126"],"import React from 'react';\r\n\r\nconst Profile = () => {\r\n    return(\r\n        <div id=\"profile\" className=\"col-span-10 text-center\">\r\n            <img className=\"cus-shadow rounded-md mx-auto mt-28\" width=\"120\" height=\"120\" src=\"./pictures/profile.jpg\"/>\r\n            <div className=\"pt-4 mx-32\">\r\n                <p className=\"text-title\">Hi there, my name is Jaka!</p>\r\n                <p className=\"side-text\">My name is Jaka Asa Baldan Ahmad, i’m just a random informatics student at Universitas Negeri Malang since 2019. I’m interested in back-end web development especially things about NodeJS, Codeigniter, and Laravel.</p>\r\n            </div>\r\n        </div>\r\n    )\r\n}\r\n\r\nexport default Profile;","C:\\Users\\madhanel\\GudangKode\\ReactJS\\Portofolio\\src\\Components\\Projects.js",[],"C:\\Users\\madhanel\\GudangKode\\ReactJS\\Portofolio\\src\\Components\\SidebarLink.js",["127","128","129"],"import React from 'react';\r\n\r\n\r\nconst SidebarLink = ({size, text, active, link}) => {\r\n\r\n    return (\r\n        <button onClick={link} className={\"sidebar-link my-5 py-2 px-5 \" + (active===true ? \"act-bg cus-shadow mx-1\":\"\")}>\r\n                {(text === \"Projects\") ? <>\r\n                        <img className=\"mx-auto\" width={size} height={size} src=\"./pictures/projects-icon.svg\"/>\r\n                        </>\r\n                    : (text === \"Experience\") ? <>\r\n                        <img className=\"mx-auto\" width={size} height={size} src=\"./pictures/experience-icon.svg\"/>\r\n                        </>\r\n                    : (text === \"Contact\") ? <>\r\n                        <img className=\"mx-auto\" width={size} height={size} src=\"./pictures/contact-icon.svg\"/>\r\n                    </> : 0\r\n                }\r\n            <p className=\"side-text\">{text}</p>\r\n        </button>\r\n    )\r\n\r\n}\r\n\r\nexport default SidebarLink","C:\\Users\\madhanel\\GudangKode\\ReactJS\\Portofolio\\src\\Components\\ProjectsList.js",["130"],"import React from 'react'\r\n\r\nconst ProjectsList = () => {\r\n    return (\r\n    <div className=\"col-span-1 p-3 act-bg cus-shadow\">\r\n        <img src=\"./pictures/projects-pic.png\" className=\"object-fill rounded-md h-32 w-full\"/>\r\n        <div className=\"flex justify-between\">\r\n            <div className=\"pl-3\">\r\n                <h3 className=\"sub-title-text mt-2\">KARYAKU</h3>\r\n                <p className=\"side-text\">As <b className=\"font-bold\">Backend Developer</b></p>\r\n            </div>\r\n            <button style={{backgroundColor: \"#37393E\", color:\"#cdcdcd\"}}\r\n                className=\"project-btn cus-shadow w-12 h-12 mt-5 mr-3 rounded-full font-bold \r\n                text-3xl text-center\">\r\n                &gt;\r\n            </button>\r\n        </div>\r\n    </div>\r\n    )\r\n}\r\n\r\nexport default ProjectsList","C:\\Users\\madhanel\\GudangKode\\ReactJS\\Portofolio\\src\\Components\\ProjectsDetail.js",["131","132","133"],"C:\\Users\\madhanel\\GudangKode\\ReactJS\\portofolio\\src\\Components\\ProjectsDetail.js",["134"],"import React from 'react'\r\nimport Carousel from 'react-multi-carousel';\r\n\r\nconst responsive = {\r\n  superLargeDesktop: {\r\n    // the naming can be any, depends on you.\r\n    breakpoint: { max: 4000, min: 3000 },\r\n    items: 1\r\n  },\r\n  desktop: {\r\n    breakpoint: { max: 3000, min: 1024 },\r\n    items: 1\r\n  },\r\n  tablet: {\r\n    breakpoint: { max: 1024, min: 464 },\r\n    items: 1\r\n  },\r\n  mobile: {\r\n    breakpoint: { max: 464, min: 0 },\r\n    items: 1\r\n  }\r\n};\r\n\r\nconst ProjectsDetail = ({data, handler}) => {\r\n    return (\r\n    <div id=\"project-detail\" className=\"main-page side-bg cus-shadow p-5 lg:p-10 rounded-md\">\r\n        <div className=\"grid grid-cols-1 lg:grid-cols-6 gap-x-10\">\r\n            <div className=\"col-span-4\">\r\n                <Carousel responsive={responsive}\r\n                swipeable={true}\r\n                draggable={true}>\r\n                  {\r\n                    data.img.map((i) =>\r\n                      <img class=\"object-fill w-full rounded-lg h-64 lg:h-72\" src={\"./pictures/projects/\"+i}/>\r\n                    )\r\n                  }\r\n                </Carousel>\r\n            </div>\r\n            <div className=\"col-span-2\">\r\n                <p className=\"text-title\">{data.title}</p>\r\n                <p className=\"sub-title-text\">Team: <span className=\"side-text ml-2\">{data.team}</span></p>\r\n                <p className=\"sub-title-text\">Technologies:</p>\r\n                <ul className=\"side-text list-inside list-disc\">\r\n                    {\r\n                      data.technologies.map((tech) =>\r\n                        <li>{tech}</li>\r\n                      )\r\n                    }\r\n                </ul>\r\n            </div>\r\n        </div>\r\n        <div class=\"mt-6\">\r\n            <p className=\"text-desc text-justify leading-relaxed text-lg\">{data.desc}</p>\r\n            <button onClick={() => {handler.backBtn()}} style={{backgroundColor: \"#37393E\", color:\"#cdcdcd\"}}\r\n                className=\"project-btn cus-shadow p-2 rounded-lg font-bold \r\n                text-lg text-center lg:float-right\">\r\n                 &#8592; Back\r\n            </button>\r\n        </div>\r\n\r\n                \r\n    </div>\r\n    )\r\n}\r\n\r\nexport default ProjectsDetail",["135","136"],"C:\\Users\\madhanel\\GudangKode\\ReactJS\\portofolio\\src\\Components\\Experiences.js",[],"C:\\Users\\madhanel\\GudangKode\\ReactJS\\portofolio\\src\\Components\\ExperienceList.js",["137"],"import React from 'react'\r\n\r\nconst ExperienceList = ({data}) => {\r\n    return (\r\n    <div className=\"list-anim col-span-1 p-3 act-bg cus-shadow\">\r\n        <div className=\"grid grid-cols-12\">\r\n            <div className=\"col-span-3 lg:col-span-1\">\r\n                <img src={\"./pictures/experiences/\"+data.img} className=\"object-fill rounded-full h-16 w-16 lg:w-16 cus-shadow mt-2\"/>\r\n            </div>\r\n            <div className=\"col-span-9 lg:col-span-11\">\r\n       